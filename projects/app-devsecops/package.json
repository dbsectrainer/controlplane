{
  "name": "project3",
  "version": "1.0.0",
  "description": "DevOps Pipeline for Containerized Application",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.js",
    "test:smoke": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.smoke.config.js",
    "lint": "eslint .",
    "docker:dev": "docker-compose -f docker/docker-compose.yml up app-dev",
    "docker:prod": "docker-compose -f docker/docker-compose.yml up app",
    "docker:test": "docker-compose -f docker/docker-compose.yml run --rm test",
    "docker:test:integration": "docker-compose -f docker/docker-compose.yml run --rm test-integration",
    "docker:test:smoke": "docker-compose -f docker/docker-compose.yml run --rm test-smoke",
    "docker:test:all": "npm run docker:test && npm run docker:test:integration && npm run docker:test:smoke"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "prom-client": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "express-winston": "^4.2.0",
    "node-vault": "^0.10.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "axios": "^1.6.7",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "ISC"
}
